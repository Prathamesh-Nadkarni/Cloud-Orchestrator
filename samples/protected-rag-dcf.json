{
    "nodes": [
        {
            "id": "node-internet",
            "type": "cloud",
            "position": {
                "x": 100,
                "y": 100
            },
            "data": {
                "type": "internet",
                "provider": "aws",
                "label": "Internet",
                "name": "public-web"
            }
        },
        {
            "id": "node-ai-gw",
            "type": "cloud",
            "position": {
                "x": 400,
                "y": 100
            },
            "data": {
                "type": "aiGateway",
                "provider": "aws",
                "label": "AI Gateway",
                "name": "ai-frontdoor",
                "authMode": "oauth2"
            }
        },
        {
            "id": "node-model",
            "type": "cloud",
            "position": {
                "x": 400,
                "y": 300
            },
            "data": {
                "type": "modelServing",
                "provider": "aws",
                "label": "LLM Serving",
                "name": "llama-3",
                "authMode": "jwt",
                "containsTrainingData": true,
                "containsPII": true,
                "redactionEnabled": true
            }
        },
        {
            "id": "node-vdb",
            "type": "cloud",
            "position": {
                "x": 700,
                "y": 300
            },
            "data": {
                "type": "vectorDB",
                "provider": "aws",
                "label": "Vector Database (Private)",
                "name": "pinecone-index",
                "containsTrainingData": true,
                "internetReachable": false
            }
        }
    ],
    "edges": [
        {
            "id": "edge-1",
            "source": "node-internet",
            "target": "node-ai-gw",
            "data": {
                "protocol": "tcp",
                "port": "443"
            }
        },
        {
            "id": "edge-2",
            "source": "node-ai-gw",
            "target": "node-model",
            "data": {
                "protocol": "tcp",
                "port": "8080",
                "payloadType": "prompts"
            }
        },
        {
            "id": "edge-3",
            "source": "node-model",
            "target": "node-vdb",
            "data": {
                "protocol": "tcp",
                "port": "5432",
                "trafficClass": "embeddings"
            }
        }
    ],
    "dcf": {
        "smartGroups": [
            {
                "uuid": "sg-gw",
                "name": "ai-gateways",
                "resourceType": "virtual_machine",
                "aiRole": "aiGateway",
                "matchExpressions": [
                    {
                        "type": "name",
                        "operator": "CONTAINS",
                        "value": "frontdoor"
                    }
                ]
            },
            {
                "uuid": "sg-model",
                "name": "llm-servers",
                "resourceType": "virtual_machine",
                "aiRole": "modelServing",
                "matchExpressions": [
                    {
                        "type": "name",
                        "operator": "CONTAINS",
                        "value": "llama"
                    }
                ]
            },
            {
                "uuid": "sg-vdb",
                "name": "vector-dbs",
                "resourceType": "database",
                "aiRole": "vectorDB",
                "matchExpressions": [
                    {
                        "type": "name",
                        "operator": "CONTAINS",
                        "value": "pinecone"
                    }
                ]
            }
        ],
        "policies": [
            {
                "uuid": "pol-1",
                "name": "allow-gw-to-model",
                "action": "ALLOW",
                "protocol": "TCP",
                "port": "8080",
                "srcSmartGroups": [
                    "sg-gw"
                ],
                "dstSmartGroups": [
                    "sg-model"
                ],
                "logging": true
            },
            {
                "uuid": "pol-2",
                "name": "allow-model-to-vdb",
                "action": "ALLOW",
                "protocol": "TCP",
                "port": "5432",
                "srcSmartGroups": [
                    "sg-model"
                ],
                "dstSmartGroups": [
                    "sg-vdb"
                ],
                "logging": false
            },
            {
                "uuid": "pol-3",
                "name": "deny-all-other",
                "action": "DENY",
                "protocol": "ANY",
                "port": "ANY",
                "srcSmartGroups": [
                    "ANY"
                ],
                "dstSmartGroups": [
                    "ANY"
                ],
                "logging": true
            }
        ]
    }
}